rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' || 
        request.auth.token.isAdmin == true
      );
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // 1. Users profiles
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // 2. Themes configurations
    match /themes/{themeId} {
      allow read, write: if isAuthenticated();
    }

    // 3. Lecture Status
    match /lecture_status/{statusId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 4. Quiz States
    match /quiz_states/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 5. Flat Submissions (flat quiz responses)
    match /submissions/{docId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // 6. Feedback
    match /feedback/{docId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // 7. Quiz Submissions (nested by subject and session)
    // Path: /quiz_submissions/{subjectId}/{sessionId}/{studentUid}
    match /quiz_submissions/{subjectId}/{sessionId}/{studentUid} {
      allow read: if isOwner(studentUid) || isAdmin();
      allow write: if isOwner(studentUid) || isAdmin();
    }

    // 8. Playgrounds
    match /playgrounds/{playgroundId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
